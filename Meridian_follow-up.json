    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a short, friendly follow-up email for a real estate lead who hasn't replied to our first message.\n\nLead name: {{ $json.fields.Name }}\nTheir original message: {{ $json.fields.Message }}\nCategory: {{ $json.fields.Category }}\n\nTone guidelines per category:\n- Hot Lead: slightly more urgent, mention that properties move fast and we want to make sure they don't miss out\n- Warm Lead: casual and helpful, offer to answer any questions they might have\n- Just Browsing: zero pressure, remind them we're here when they're ready, offer a free market update\n\nKeep it under 80 words. Do not use the word \"just\" (e.g. avoid \"just checking in\"). Do not use abbreviations like ASAP; write out \"as soon as possible\" instead. End with a proper closing line such as \"Best regards,\" followed by \"The Meridian Realty Team.\" Return only the email body, no subject line.",
        "messages": { "messageValues": [] },
        "batching": {}
      },
